{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**"
    ],
    "rewrites": [
      {
        "source": "/generarHanziPDF",
        "function": "generarHanziPDF"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default"
    }
  ],
  "emulators": {
    "hosting": {
      "host": "0.0.0.0",
      "port": 5000
    },
    "functions": {
      "host": "0.0.0.0",
      "port": 5001
    }
  }
}
